<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Close_Note</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status__c, 'Completed'), ISBLANK(Close_Note__c))</errorConditionFormula>
    <errorMessage>Kapanış notu zorunludur</errorMessage>
</ValidationRule>
