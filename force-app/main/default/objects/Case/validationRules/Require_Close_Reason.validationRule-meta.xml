<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Close_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status, 'Closed'), ISBLANK(Close_Reason__c))</errorConditionFormula>
    <errorMessage>Kapanış nedeni zorunludur</errorMessage>
</ValidationRule>
