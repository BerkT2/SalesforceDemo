<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Service_Eligibility_Check</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status, 'Service'), Is_Service_Eligible__c = FALSE, NOT(ISNEW()))</errorConditionFormula>
    <errorMessage>Bu başvuru nedeni servise atamaya uygun değildir</errorMessage>
</ValidationRule>
